@page "/tests"
@rendermode InteractiveServer
@using StudentWifiMonitoring.Web.DTOs.Tests
@using StudentWifiMonitoring.Web.Services.Interfaces
@inject ITestManagementService TestManagementService
@inject ITeacherAuthService TeacherAuth
@inject PersistentComponentState AppState
@inject ILogger<Tests> Logger

<PageTitle>Toetsen — Toetslocker</PageTitle>

@if (!isTeacher)
{
    <div class="tl-empty">
        <div class="ic"><TLIcon Name="lock" Size="32" /></div>
        <h3>Geen toegang</h3>
        <p>Deze pagina is alleen beschikbaar voor docenten.</p>
    </div>
}
else
{
    @if (showConfirmModal && testToDeactivate != null)
    {
        <div class="tl-modal-scrim" @onclick="CancelDeactivate">
            <div class="tl-modal tl-confirm-modal" @onclick:stopPropagation="true">
                <div class="tl-modal-head">
                    <TLIcon Name="alert" Size="20" />
                    <div class="t">Toets inactief zetten</div>
                    <button class="x" @onclick="CancelDeactivate"><TLIcon Name="close" Size="18" /></button>
                </div>
                <div class="tl-modal-body">
                    <div class="tl-confirm-item">
                        <strong>@testToDeactivate.Name</strong>
                        <small>@testToDeactivate.StartTime.ToLocalTime().ToString("dd-MM-yyyy HH:mm") – @testToDeactivate.EndTime.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</small>
                    </div>
                    <div class="tl-confirm-warn">
                        <TLIcon Name="alert" Size="16" /> Alle momenteel verbonden studenten worden automatisch gedisconnect!
                    </div>
                </div>
                <div class="tl-modal-foot">
                    <button class="tl-btn tl-btn-ghost" @onclick="CancelDeactivate">Annuleren</button>
                    <button class="tl-btn tl-btn-red" style="margin-left:10px" @onclick="ConfirmDeactivateAsync">
                        <TLIcon Name="stop" Size="16" /> Ja, inactief zetten
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="tl-ph">
        <h1>Toetsen</h1>
        <p>Aanmaken, bewerken en beheren van toetssessies</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="tl-confirm-warn" style="margin-bottom:16px">
            <TLIcon Name="alert" Size="16" /> @errorMessage
            <button style="margin-left:auto;background:none;border:none;cursor:pointer;color:inherit" @onclick="() => errorMessage = string.Empty"><TLIcon Name="close" Size="16" /></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="tl-alert-ok">
            <TLIcon Name="check" Size="18" /> @successMessage
            <button class="x" @onclick="() => successMessage = string.Empty"><TLIcon Name="close" Size="16" /></button>
        </div>
    }

    @if (editingTest == null)
    {
        <div class="tl-formcard">
            <div class="tl-card-h">
                <div class="ic"><TLIcon Name="plus" Size="18" /></div>
                Nieuwe toets aanmaken
            </div>
            <div class="tl-fld">
                <label>Toetsnaam</label>
                <input type="text" class="tl-in" @bind="newName" placeholder="Voer toetsnaam in" />
            </div>
            <div class="tl-grid2">
                <div class="tl-fld">
                    <label>Starttijd (lokale tijd)</label>
                    <input type="datetime-local" class="tl-in" @bind="startTimeLocal" />
                </div>
                <div class="tl-fld">
                    <label>Eindtijd (lokale tijd)</label>
                    <input type="datetime-local" class="tl-in" @bind="endTimeLocal" />
                </div>
            </div>
            <button class="tl-btn tl-btn-brand" @onclick="CreateTestAsync">
                <TLIcon Name="plus" Size="18" /> Toets aanmaken
            </button>
        </div>
    }
    else
    {
        <div class="tl-formcard" style="border-color:#F8E2AE">
            <div class="tl-card-h">
                <div class="ic" style="background:#FEF3DA;color:#97650A"><TLIcon Name="edit" Size="18" /></div>
                Toets bewerken
            </div>
            <div class="tl-fld">
                <label>Toetsnaam</label>
                <input type="text" class="tl-in" @bind="editName" placeholder="Voer toetsnaam in" />
            </div>
            <div class="tl-grid2">
                <div class="tl-fld">
                    <label>Starttijd (lokale tijd)</label>
                    <input type="datetime-local" class="tl-in" @bind="editStartTimeLocal" />
                </div>
                <div class="tl-fld">
                    <label>Eindtijd (lokale tijd)</label>
                    <input type="datetime-local" class="tl-in" @bind="editEndTimeLocal" />
                </div>
            </div>
            <div style="display:flex;gap:10px">
                <button class="tl-btn tl-btn-brand" @onclick="SaveEditAsync">
                    <TLIcon Name="check" Size="18" /> Opslaan
                </button>
                <button class="tl-btn tl-btn-ghost" @onclick="CancelEdit">
                    <TLIcon Name="close" Size="18" /> Annuleren
                </button>
            </div>
        </div>
    }

    <div class="tl-listcard">
        <div class="tl-card-h">
            <div class="ic"><TLIcon Name="list" Size="18" /></div>
            Bestaande toetsen
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <button class="tl-btn tl-btn-ghost" style="margin-left:auto;padding:6px 12px;font-size:13px" @onclick="ClearSearchAsync">
                    <TLIcon Name="refresh" Size="14" /> Toon alle
                </button>
            }
        </div>

        <div class="tl-search-bar">
            <TLIcon Name="search" Size="16" />
            <input type="text"
                   placeholder="Zoek op toetsnaam…"
                   @bind="searchTerm"
                   @bind:event="oninput"
                   @bind:after="OnSearchChangedAsync" />
        </div>

        @if (isLoading)
        {
            <div class="tl-empty">
                <p>Laden…</p>
            </div>
        }
        else if (pagedResult == null || pagedResult.Items.Count == 0)
        {
            <div class="tl-empty">
                <div class="ic"><TLIcon Name="doc" Size="32" /></div>
                @if (string.IsNullOrEmpty(searchTerm))
                {
                    <h3>Nog geen toetsen</h3>
                    <p>Maak je eerste toets aan met het formulier hierboven.</p>
                }
                else
                {
                    <h3>Geen resultaten</h3>
                    <p>Geen toetsen gevonden voor "<strong>@searchTerm</strong>".</p>
                    <a @onclick="ClearSearchAsync" @onclick:preventDefault style="cursor:pointer">Toon alle toetsen</a>
                }
            </div>
        }
        else
        {
            @foreach (var t in pagedResult.Items)
            {
                var isActive = t.IsActive;
                <div class="tl-toets-item @(isActive ? "active" : "")">
                    <div class="info">
                        <div class="tn">
                            @t.Name
                            @if (isActive)
                            {
                                <span class="tl-badge-st act">ACTIEF</span>
                            }
                            else
                            {
                                <span class="tl-badge-st inact">INACTIEF</span>
                            }
                        </div>
                        <div class="meta">
                            <span><TLIcon Name="calendar" Size="13" /> Start: <b>@t.StartTime.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</b></span>
                            <span><TLIcon Name="flag" Size="13" /> Eind: <b>@t.EndTime.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</b></span>
                        </div>
                    </div>
                    <div class="acts">
                        @if (isActive)
                        {
                            <button class="tl-btn tl-deact-btn"
                                    @onclick="() => ShowDeactivateConfirmAsync(t)"
                                    disabled="@(editingTest != null)">
                                <TLIcon Name="stop" Size="16" /> Inactief
                            </button>
                        }
                        <button class="tl-btn tl-btn-ghost"
                                @onclick="() => StartEdit(t)"
                                disabled="@(editingTest != null)">
                            <TLIcon Name="edit" Size="16" /> Bewerken
                        </button>
                    </div>
                </div>
            }

            @if (pagedResult.TotalPages > 1)
            {
                <div class="tl-pager">
                    <button @onclick="PreviousPageAsync" disabled="@(!pagedResult.HasPreviousPage)">&#8592; Vorige</button>
                    @for (int i = 1; i <= pagedResult.TotalPages; i++)
                    {
                        var pageNumber = i;
                        <button class="@(pagedResult.PageNumber == pageNumber ? "active" : "")" @onclick="() => GoToPageAsync(pageNumber)">@pageNumber</button>
                    }
                    <button @onclick="NextPageAsync" disabled="@(!pagedResult.HasNextPage)">Volgende &#8594;</button>
                </div>
            }

            <p class="tl-pager-info">
                @if (pagedResult.TotalPages > 1)
                {
                    <text>Pagina @pagedResult.PageNumber van @pagedResult.TotalPages · </text>
                }
                <strong>@pagedResult.TotalCount</strong> toets@(pagedResult.TotalCount != 1 ? "en" : "")
            </p>
        }
    </div>
}

@code {
    private bool isTeacher;
    private PersistingComponentStateSubscription _persistSubscription;

    // Paginatie en zoeken
    private PagedResultDto<TestSessionDto>? pagedResult;
    private string searchTerm = string.Empty;
    private int currentPage = 1;
    private const int PageSize = 10;
    private bool isLoading = true;

    // Nieuwe toets aanmaken
    private string newName = string.Empty;
    private DateTime startTimeLocal = DateTime.Now;
    private DateTime endTimeLocal = DateTime.Now.AddHours(2);

    // Toets bewerken
    private TestSessionDto? editingTest;
    private string editName = string.Empty;
    private DateTime editStartTimeLocal;
    private DateTime editEndTimeLocal;

    // Bevestigingsmodal voor inactief zetten
    private bool showConfirmModal = false;
    private TestSessionDto? testToDeactivate;

    // Berichten
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _persistSubscription = AppState.RegisterOnPersisting(PersistAuthState);

        if (AppState.TryTakeFromJson<bool>("isTeacher", out bool restored))
        {
            isTeacher = restored;
        }
        else
        {
            isTeacher = TeacherAuth.IsTeacher();
        }

        if (!isTeacher)
        {
            return;
        }

        await LoadTestsAsync();
    }

    private Task PersistAuthState()
    {
        AppState.PersistAsJson("isTeacher", isTeacher);
        return Task.CompletedTask;
    }

    /// <summary>
    /// Laadt toetsen via de service met paginatie en filtering.
    /// </summary>
    private async Task LoadTestsAsync()
    {
        isLoading = true;
        try
        {
            pagedResult = await TestManagementService.GetPagedTestsAsync(searchTerm, currentPage, PageSize);
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Handler voor zoekterm wijziging - reset naar pagina 1.
    /// </summary>
    private async Task OnSearchChangedAsync()
    {
        currentPage = 1;
        await LoadTestsAsync();
    }

    /// <summary>
    /// Wist de zoekterm en herlaadt alle toetsen.
    /// </summary>
    private async Task ClearSearchAsync()
    {
        searchTerm = string.Empty;
        currentPage = 1;
        await LoadTestsAsync();
    }

    /// <summary>
    /// Navigeert naar de vorige pagina.
    /// </summary>
    private async Task PreviousPageAsync()
    {
        if (pagedResult?.HasPreviousPage == true)
        {
            currentPage--;
            await LoadTestsAsync();
        }
    }

    /// <summary>
    /// Navigeert naar de volgende pagina.
    /// </summary>
    private async Task NextPageAsync()
    {
        if (pagedResult?.HasNextPage == true)
        {
            currentPage++;
            await LoadTestsAsync();
        }
    }

    /// <summary>
    /// Navigeert naar een specifieke pagina.
    /// </summary>
    private async Task GoToPageAsync(int pageNumber)
    {
        if (pageNumber >= 1 && pageNumber <= (pagedResult?.TotalPages ?? 1))
        {
            currentPage = pageNumber;
            await LoadTestsAsync();
        }
    }

    /// <summary>
    /// Maakt een nieuwe toets aan via de service.
    /// </summary>
    private async Task CreateTestAsync()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            var createDto = new TestSessionCreateDto
            {
                Name = newName,
                StartTimeLocal = startTimeLocal,
                EndTimeLocal = endTimeLocal
            };

            var result = await TestManagementService.CreateTestAsync(createDto);

            if (result.Success)
            {
                await LoadTestsAsync();
                successMessage = $"Toets '{newName.Trim()}' succesvol aangemaakt.";

                // Reset form
                newName = string.Empty;
                startTimeLocal = DateTime.Now;
                endTimeLocal = DateTime.Now.AddHours(2);
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Er is een fout opgetreden.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fout bij het aanmaken van toets");
            errorMessage = "Er is een fout opgetreden bij het aanmaken van de toets.";
        }
    }

    /// <summary>
    /// Toont bevestigingsmodal voordat toets inactief wordt gezet.
    /// </summary>
    private Task ShowDeactivateConfirmAsync(TestSessionDto test)
    {
        testToDeactivate = test;
        showConfirmModal = true;
        errorMessage = string.Empty;
        successMessage = string.Empty;
        return Task.CompletedTask;
    }

    /// <summary>
    /// Annuleert het inactief zetten.
    /// </summary>
    private void CancelDeactivate()
    {
        showConfirmModal = false;
        testToDeactivate = null;
    }

    /// <summary>
    /// Bevestigt en voert het inactief zetten uit via de service.
    /// </summary>
    private async Task ConfirmDeactivateAsync()
    {
        if (testToDeactivate != null)
        {
            showConfirmModal = false;
            await SetInactiveAsync(testToDeactivate);
            testToDeactivate = null;
        }
    }

    /// <summary>
    /// Zet een actieve toets inactief via de service.
    /// </summary>
    private async Task SetInactiveAsync(TestSessionDto test)
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            var result = await TestManagementService.DeactivateTestAsync(test.Id);

            await LoadTestsAsync();

            if (result.DisconnectedStudentsCount > 0)
            {
                successMessage = $"Toets '{result.TestName}' is inactief gezet en {result.DisconnectedStudentsCount} actieve verbinding(en) zijn gesloten.";
            }
            else
            {
                successMessage = $"Toets '{result.TestName}' is inactief gezet.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fout bij het inactief zetten van toets");
            errorMessage = "Er is een fout opgetreden bij het inactief zetten van de toets.";
        }
    }

    /// <summary>
    /// Start bewerkingsmodus voor een toets.
    /// </summary>
    private void StartEdit(TestSessionDto test)
    {
        editingTest = test;
        editName = test.Name;
        editStartTimeLocal = test.StartTime.ToLocalTime();
        editEndTimeLocal = test.EndTime.ToLocalTime();

        errorMessage = string.Empty;
        successMessage = string.Empty;
    }

    /// <summary>
    /// Annuleert bewerkingsmodus.
    /// </summary>
    private void CancelEdit()
    {
        editingTest = null;
        editName = string.Empty;
        errorMessage = string.Empty;
    }

    /// <summary>
    /// Slaat bewerkingen op via de service.
    /// </summary>
    private async Task SaveEditAsync()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            if (editingTest == null)
            {
                return;
            }

            var updateDto = new TestSessionUpdateDto
            {
                Id = editingTest.Id,
                Name = editName,
                StartTimeLocal = editStartTimeLocal,
                EndTimeLocal = editEndTimeLocal
            };

            var result = await TestManagementService.UpdateTestAsync(updateDto);

            if (result.Success)
            {
                await LoadTestsAsync();
                successMessage = $"Toets '{editName.Trim()}' succesvol bijgewerkt.";

                // Reset edit mode
                editingTest = null;
                editName = string.Empty;
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Er is een fout opgetreden.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fout bij het opslaan van toets");
            errorMessage = "Er is een fout opgetreden bij het opslaan van de toets.";
        }
    }

    public void Dispose()
    {
        _persistSubscription.Dispose();
    }
}
