@page "/tests"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using StudentWifiMonitoring.Web.Data
@using StudentWifiMonitoring.Web.Domain
@using StudentWifiMonitoring.Web.Services
@using StudentWifiMonitoring.Web.Hubs
@using Microsoft.AspNetCore.SignalR
@inject AppDbContext Db
@inject ILogger<Tests> Logger
@inject IHubContext<StatusHub> HubContext
@inject TestManagementService TestManagementService

<PageTitle>Beheer Toetsen</PageTitle>

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h3>📝 Beheer Toetsen</h3>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @errorMessage
                    <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @successMessage
                    <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
                </div>
            }

            @if (editingTest == null)
            {
                <!-- Nieuwe Toets Aanmaken -->
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">➕ Nieuwe Toets Aanmaken</h5>
                        
                        <div class="mb-3">
                            <label for="testName" class="form-label">Toetsnaam:</label>
                            <input type="text" 
                                   class="form-control" 
                                   id="testName" 
                                   @bind="newName" 
                                   placeholder="Voer toetsnaam in" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="startTime" class="form-label">Starttijd (lokale tijd):</label>
                                <input type="datetime-local" 
                                       class="form-control" 
                                       id="startTime" 
                                       @bind="startTimeLocal" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="endTime" class="form-label">Eindtijd (lokale tijd):</label>
                                <input type="datetime-local" 
                                       class="form-control" 
                                       id="endTime" 
                                       @bind="endTimeLocal" />
                            </div>
                        </div>

                        <button class="btn btn-primary" @onclick="CreateTestAsync">
                            ➕ Toets Aanmaken
                        </button>
                    </div>
                </div>
            }
            else
            {
                <!-- Toets Bewerken -->
                <div class="card mb-4 border-warning">
                    <div class="card-body">
                        <h5 class="card-title">✏️ Toets Bewerken</h5>
                        
                        <div class="mb-3">
                            <label for="editName" class="form-label">Toetsnaam:</label>
                            <input type="text" 
                                   class="form-control" 
                                   id="editName" 
                                   @bind="editName" 
                                   placeholder="Voer toetsnaam in" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="editStartTime" class="form-label">Starttijd (lokale tijd):</label>
                                <input type="datetime-local" 
                                       class="form-control" 
                                       id="editStartTime" 
                                       @bind="editStartTimeLocal" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="editEndTime" class="form-label">Eindtijd (lokale tijd):</label>
                                <input type="datetime-local" 
                                       class="form-control" 
                                       id="editEndTime" 
                                       @bind="editEndTimeLocal" />
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-success" @onclick="SaveEditAsync">
                                💾 Opslaan
                            </button>
                            <button class="btn btn-secondary" @onclick="CancelEdit">
                                ❌ Annuleren
                            </button>
                        </div>
                    </div>
                </div>
            }

            <!-- Bestaande Toetsen met Zoeken en Paginatie -->
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">📋 Bestaande Toetsen</h5>
                    
                    <!-- Zoekbalk -->
                    <div class="mb-3">
                        <div class="input-group">
                            <span class="input-group-text">🔍</span>
                            <input type="text" 
                                   class="form-control" 
                                   placeholder="Zoek op toetsnaam..." 
                                   @bind="searchTerm"
                                   @bind:event="oninput"
                                   @bind:after="OnSearchChangedAsync" />
                            @if (!string.IsNullOrEmpty(searchTerm))
                            {
                                <button class="btn btn-outline-secondary" @onclick="ClearSearchAsync">
                                    ❌ Wissen
                                </button>
                            }
                        </div>
                    </div>

                    @if (isLoading)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Laden...</span>
                            </div>
                        </div>
                    }
                    else if (pagedResult == null || pagedResult.Items.Count == 0)
                    {
                        <p class="text-muted">
                            @if (string.IsNullOrEmpty(searchTerm))
                            {
                                <text>Nog geen toetsen aangemaakt.</text>
                            }
                            else
                            {
                                <text>Geen toetsen gevonden voor "@searchTerm".</text>
                            }
                        </p>
                    }
                    else
                    {
                        <!-- Toetsenlijst -->
                        <div class="list-group mb-3">
                            @foreach (var t in pagedResult.Items)
                            {
                                var isActive = t.IsActive;
                                <div class="list-group-item @(isActive ? "list-group-item-success" : "")">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center mb-2">
                                                <strong class="me-2">@t.Name</strong>
                                                @if (isActive)
                                                {
                                                    <span class="badge bg-success">🟢 Actief</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">⚪ Inactief</span>
                                                }
                                            </div>
                                            <div class="text-muted small">
                                                <div>
                                                    <strong>Start:</strong> @t.StartTime.ToLocalTime().ToString("dd-MM-yyyy HH:mm")
                                                </div>
                                                <div>
                                                    <strong>Eind:</strong> @t.EndTime.ToLocalTime().ToString("dd-MM-yyyy HH:mm")
                                                </div>
                                            </div>
                                        </div>
                                        <div class="d-flex flex-column gap-2">
                                            @if (isActive)
                                            {
                                                <button class="btn btn-sm btn-warning" 
                                                        @onclick="() => SetInactiveAsync(t)"
                                                        disabled="@(editingTest != null)">
                                                    ⏹️ Inactief zetten
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-primary" 
                                                    @onclick="() => StartEdit(t)"
                                                    disabled="@(editingTest != null)">
                                                ✏️ Bewerken
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Paginatie -->
                        <nav aria-label="Toetsen paginatie">
                            <ul class="pagination justify-content-center mb-3">
                                <li class="page-item @(!pagedResult.HasPreviousPage ? "disabled" : "")">
                                    <button class="page-link" @onclick="PreviousPageAsync" disabled="@(!pagedResult.HasPreviousPage)">
                                        « Vorige
                                    </button>
                                </li>
                                
                                @for (int i = 1; i <= pagedResult.TotalPages; i++)
                                {
                                    var pageNumber = i; // Capture voor lambda
                                    <li class="page-item @(pagedResult.PageNumber == pageNumber ? "active" : "")">
                                        <button class="page-link" @onclick="() => GoToPageAsync(pageNumber)">
                                            @pageNumber
                                        </button>
                                    </li>
                                }
                                
                                <li class="page-item @(!pagedResult.HasNextPage ? "disabled" : "")">
                                    <button class="page-link" @onclick="NextPageAsync" disabled="@(!pagedResult.HasNextPage)">
                                        Volgende »
                                    </button>
                                </li>
                            </ul>
                        </nav>

                        <!-- Statistieken -->
                        <div class="text-center">
                            <small class="text-muted">
                                Pagina @pagedResult.PageNumber van @pagedResult.TotalPages
                                (@pagedResult.TotalCount toets@(pagedResult.TotalCount != 1 ? "en" : ""))
                            </small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Paginatie en zoeken
    private PagedResult<TestSession>? pagedResult;
    private string searchTerm = string.Empty;
    private int currentPage = 1;
    private const int PageSize = 10;
    private bool isLoading = true;
    
    // Nieuwe toets aanmaken
    private string newName = string.Empty;
    private DateTime startTimeLocal = DateTime.Now;
    private DateTime endTimeLocal = DateTime.Now.AddHours(2);
    
    // Toets bewerken
    private TestSession? editingTest;
    private string editName = string.Empty;
    private DateTime editStartTimeLocal;
    private DateTime editEndTimeLocal;
    
    // Berichten
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadTestsAsync();
    }

    /// <summary>
    /// Laadt toetsen via de service met paginatie en filtering.
    /// </summary>
    private async Task LoadTestsAsync()
    {
        isLoading = true;
        try
        {
            pagedResult = await TestManagementService.GetPagedTestsAsync(searchTerm, currentPage, PageSize);
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Handler voor zoekterm wijziging - reset naar pagina 1.
    /// </summary>
    private async Task OnSearchChangedAsync()
    {
        currentPage = 1;
        await LoadTestsAsync();
    }

    /// <summary>
    /// Wist de zoekterm en herlaadt.
    /// </summary>
    private async Task ClearSearchAsync()
    {
        searchTerm = string.Empty;
        currentPage = 1;
        await LoadTestsAsync();
    }

    /// <summary>
    /// Navigeert naar de vorige pagina.
    /// </summary>
    private async Task PreviousPageAsync()
    {
        if (pagedResult?.HasPreviousPage == true)
        {
            currentPage--;
            await LoadTestsAsync();
        }
    }

    /// <summary>
    /// Navigeert naar de volgende pagina.
    /// </summary>
    private async Task NextPageAsync()
    {
        if (pagedResult?.HasNextPage == true)
        {
            currentPage++;
            await LoadTestsAsync();
        }
    }

    /// <summary>
    /// Navigeert naar een specifieke pagina.
    /// </summary>
    private async Task GoToPageAsync(int pageNumber)
    {
        if (pageNumber >= 1 && pageNumber <= (pagedResult?.TotalPages ?? 1))
        {
            currentPage = pageNumber;
            await LoadTestsAsync();
        }
    }

    /// <summary>
    /// Maakt een nieuwe toets aan.
    /// </summary>
    private async Task CreateTestAsync()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            if (string.IsNullOrWhiteSpace(newName))
            {
                errorMessage = "Voer een toetsnaam in.";
                return;
            }

            if (endTimeLocal <= startTimeLocal)
            {
                errorMessage = "Eindtijd moet na de starttijd liggen.";
                return;
            }

            var startUtc = DateTime.SpecifyKind(startTimeLocal, DateTimeKind.Local).ToUniversalTime();
            var endUtc = DateTime.SpecifyKind(endTimeLocal, DateTimeKind.Local).ToUniversalTime();

            var session = new TestSession 
            { 
                Name = newName.Trim(), 
                StartTime = startUtc, 
                EndTime = endUtc 
            };

            Db.TestSessions.Add(session);
            await Db.SaveChangesAsync();
            
            await LoadTestsAsync();
            
            successMessage = $"Toets '{session.Name}' succesvol aangemaakt.";
            newName = string.Empty;
            startTimeLocal = DateTime.Now;
            endTimeLocal = DateTime.Now.AddHours(2);

            Logger.LogInformation("Toets aangemaakt: {TestName} ({StartTime} - {EndTime})", 
                session.Name, session.StartTime, session.EndTime);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fout bij het aanmaken van toets");
            errorMessage = "Er is een fout opgetreden bij het aanmaken van de toets.";
        }
    }

    /// <summary>
    /// Zet een actieve toets inactief en sluit alle open verbindingen.
    /// </summary>
    private async Task SetInactiveAsync(TestSession test)
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            var now = DateTime.UtcNow;
            var disconnectCount = 0;

            test.EndTime = now.AddSeconds(-1);

            var students = await Db.Students
                .Where(s => s.TestName == test.Name)
                .ToListAsync();

            if (students.Count > 0)
            {
                var studentIds = students.Select(s => s.Id).ToList();

                var openConnections = await Db.Connections
                    .Where(c => studentIds.Contains(c.StudentId) && c.DisconnectedAt == null)
                    .ToListAsync();

                foreach (var connection in openConnections)
                {
                    connection.DisconnectedAt = now;
                    disconnectCount++;
                }

                foreach (var student in students)
                {
                    var hadOpenConnection = openConnections.Any(c => c.StudentId == student.Id);
                    if (hadOpenConnection)
                    {
                        var eventLog = new EventLog
                        {
                            StudentId = student.Id,
                            TestSessionId = test.Id,
                            EventType = EventType.Disconnected,
                            Timestamp = now
                        };
                        Db.Events.Add(eventLog);

                        await HubContext.Clients.All.SendAsync("status", new
                        {
                            mac = student.MacAddress,
                            status = "disconnected",
                            name = student.Name,
                            testName = student.TestName
                        });

                        Logger.LogInformation(
                            "Student {Name} ({MacAddress}) automatisch verbroken door toets inactief zetten: {TestName}", 
                            student.Name, student.MacAddress, test.Name);
                    }
                }
            }

            await Db.SaveChangesAsync();
            await LoadTestsAsync();
            
            if (disconnectCount > 0)
            {
                successMessage = $"Toets '{test.Name}' is inactief gezet en {disconnectCount} actieve verbinding(en) zijn gesloten.";
            }
            else
            {
                successMessage = $"Toets '{test.Name}' is inactief gezet.";
            }
            
            Logger.LogInformation("Toets inactief gezet: {TestName}, {DisconnectCount} verbindingen gesloten", 
                test.Name, disconnectCount);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fout bij het inactief zetten van toets");
            errorMessage = "Er is een fout opgetreden bij het inactief zetten van de toets.";
        }
    }

    /// <summary>
    /// Start bewerkingsmodus voor een toets.
    /// </summary>
    private void StartEdit(TestSession test)
    {
        editingTest = test;
        editName = test.Name;
        editStartTimeLocal = test.StartTime.ToLocalTime();
        editEndTimeLocal = test.EndTime.ToLocalTime();
        
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }

    /// <summary>
    /// Annuleert bewerkingsmodus.
    /// </summary>
    private void CancelEdit()
    {
        editingTest = null;
        editName = string.Empty;
        errorMessage = string.Empty;
    }

    /// <summary>
    /// Slaat bewerkingen op.
    /// </summary>
    private async Task SaveEditAsync()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            if (editingTest == null)
            {
                return;
            }

            if (string.IsNullOrWhiteSpace(editName))
            {
                errorMessage = "Voer een toetsnaam in.";
                return;
            }

            if (editEndTimeLocal <= editStartTimeLocal)
            {
                errorMessage = "Eindtijd moet na de starttijd liggen.";
                return;
            }

            var startUtc = DateTime.SpecifyKind(editStartTimeLocal, DateTimeKind.Local).ToUniversalTime();
            var endUtc = DateTime.SpecifyKind(editEndTimeLocal, DateTimeKind.Local).ToUniversalTime();

            editingTest.Name = editName.Trim();
            editingTest.StartTime = startUtc;
            editingTest.EndTime = endUtc;

            await Db.SaveChangesAsync();
            await LoadTestsAsync();

            successMessage = $"Toets '{editingTest.Name}' succesvol bijgewerkt.";

            Logger.LogInformation("Toets bijgewerkt: {TestName} ({StartTime} - {EndTime})", 
                editingTest.Name, editingTest.StartTime, editingTest.EndTime);

            editingTest = null;
            editName = string.Empty;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Fout bij het opslaan van toets");
            errorMessage = "Er is een fout opgetreden bij het opslaan van de toets.";
        }
    }
}