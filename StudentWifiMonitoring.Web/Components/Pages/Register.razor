@page "/register"
@layout StudentLayout
@rendermode InteractiveServer
@using StudentWifiMonitoring.Web.DTOs.Students
@using StudentWifiMonitoring.Web.Services.Interfaces
@inject IStudentRegistrationService RegistrationService
@inject IHttpContextAccessor HttpContextAccessor
@inject ILogger<Register> Logger
@inject StudentWifiMonitoring.Web.Services.IMacResolver MacResolver
@inject StudentWifiMonitoring.Web.Services.Interfaces.IMyScreenService MyScreenService
@inject NavigationManager Nav

<PageTitle>Registreren — Toetslocker</PageTitle>

@if (_isStudentActiveInTest)
{
    <div class="tl-stu connected tl-root">
        <div class="tl-stu-bar">
            <div class="tl-stu-brand">
                <TLLogoMark Size="28" /> Toetslocker
            </div>
            <div class="tl-realtime"><i></i> Realtime</div>
        </div>
        <div class="tl-stu-body">
            <div class="tl-badge"><TLIcon Name="wifi" Size="54" Stroke="2.4" /></div>
            <h1 class="tl-stu-title">Al actief</h1>
            <p class="tl-stu-sub">Je bent al actief in een toets. Ga naar Mijn Scherm om je status te bekijken.</p>
            <a href="/myscreen" class="tl-bigbtn">
                <TLIcon Name="arrow" Size="20" /> Naar Mijn Scherm
            </a>
        </div>
    </div>
}
else if (_activeSession == null)
{
    <div class="tl-stu blocked tl-root">
        <div class="tl-stu-bar">
            <div class="tl-stu-brand">
                <TLLogoMark Size="28" /> Toetslocker
            </div>
        </div>
        <div class="tl-stu-body">
            <div class="tl-badge"><TLIcon Name="lock" Size="54" Stroke="2.4" /></div>
            <h1 class="tl-stu-title">Geen toets</h1>
            <p class="tl-stu-sub">Er is momenteel geen actieve toets. Registratie is alleen mogelijk tijdens een actieve toets.</p>
        </div>
    </div>
}
else
{
    <div class="tl-stu joining tl-root">
        <div class="tl-stu-bar">
            <div class="tl-stu-brand">
                <TLLogoMark Size="28" /> Toetslocker
            </div>
        </div>
        <div class="tl-stu-body">
            <div class="tl-badge"><TLLogoMark Size="58" /></div>
            <h1 class="tl-stu-title">Welkom</h1>
            <p class="tl-stu-sub">Vul je naam in om aan te melden voor <strong>@_activeSession.Name</strong>.</p>

            <div class="tl-join">
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="tl-warn">
                        <TLIcon Name="alert" Size="16" /> @_errorMessage
                    </div>
                }

                <div class="tl-field">
                    <label for="studentName">Je naam</label>
                    <input type="text"
                           class="tl-input"
                           id="studentName"
                           @bind="_studentName"
                           placeholder="Voor- en achternaam"
                           disabled="@_isProcessing" />
                </div>

                <button class="tl-bigbtn"
                        @onclick="RegisterAsync"
                        disabled="@(_isProcessing || string.IsNullOrWhiteSpace(_studentName))">
                    @if (_isProcessing)
                    {
                        <TLIcon Name="refresh" Size="20" />
                        <span>Bezig...</span>
                    }
                    else
                    {
                        <TLIcon Name="wifi" Size="20" />
                        <span>Verbinden met toets</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private ActiveTestSessionDto? _activeSession;
    private string _studentName = string.Empty;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;
    private bool _isProcessing = false;
    private bool _isStudentActiveInTest = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadActiveSessionAsync();
        await CheckStudentActiveStatusAsync();
    }

    private async Task CheckStudentActiveStatusAsync()
    {
        try
        {
            var ip = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString();
            if (string.IsNullOrEmpty(ip)) return;
            var mac = MacResolver.GetMacForIp(ip);
            if (string.IsNullOrEmpty(mac)) return;
            var status = await MyScreenService.GetStudentConnectionStatusAsync(mac);
            _isStudentActiveInTest = status.IsConnected && !status.IsTestComplete;
        }
        catch
        {
            _isStudentActiveInTest = false;
        }
    }

    /// <summary>
    /// Laadt de huidige actieve toetssessie via de service.
    /// </summary>
    private async Task LoadActiveSessionAsync()
    {
        _activeSession = await RegistrationService.GetActiveTestSessionAsync();
    }

    /// <summary>
    /// Registreert de student voor de actieve toets via de service.
    /// Verzamelt het client IP-adres en geeft dit door aan de service.
    /// </summary>
    private async Task RegisterAsync()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;
        _isProcessing = true;

        try
        {
            // Valideer naam (eerste check in UI voor snelle feedback)
            if (string.IsNullOrWhiteSpace(_studentName))
            {
                _errorMessage = "Voer een geldige naam in.";
                return;
            }

            // Controleer opnieuw of er een actieve sessie is
            if (_activeSession == null)
            {
                _errorMessage = "Er is geen actieve toets meer. Probeer de pagina te vernieuwen.";
                return;
            }

            // Bepaal client IP-adres (praktisch om hier te doen vanwege HttpContext toegang)
            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext?.Connection?.RemoteIpAddress == null)
            {
                Logger.LogWarning("Kan client IP-adres niet bepalen tijdens registratie");
                _errorMessage = "Kan je IP-adres niet bepalen. Neem contact op met de docent.";
                return;
            }

            var clientIp = httpContext.Connection.RemoteIpAddress.ToString();

            // Registreer via service
            var request = new StudentRegistrationRequestDto
            {
                StudentName = _studentName,
                ClientIpAddress = clientIp
            };

            var result = await RegistrationService.RegisterStudentAsync(request);

            if (result.Success)
            {
                Nav.NavigateTo("/myscreen");
                return;
            }
            else
            {
                _errorMessage = result.ErrorMessage ?? "Er is een fout opgetreden.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Onverwachte fout tijdens registratie van student");
            _errorMessage = "Er is een onverwachte fout opgetreden. Probeer het opnieuw of neem contact op met de docent.";
        }
        finally
        {
            _isProcessing = false;
        }
    }
}
