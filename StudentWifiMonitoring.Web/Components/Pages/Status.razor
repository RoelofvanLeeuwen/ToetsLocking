@page "/status"
@using StudentWifiMonitoring.Web.DTOs.Status
@using StudentWifiMonitoring.Web.Services.Interfaces
@inject IStatusService StatusService
@implements IAsyncDisposable

<TeacherGuard>
<h3>Connected Students</h3>

@if (connected == null)
{
    <p>Loading…</p>
}
else
{
    <ul>
        @foreach (ConnectedStudentDto s in connected)
        {
            <li>@s.Name (@s.MacAddress)</li>
        }
    </ul>
}
</TeacherGuard>

@code {
    private List<ConnectedStudentDto>? connected;
    private PeriodicTimer? timer;
    private CancellationTokenSource? cts;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();

        cts = new CancellationTokenSource();
        timer = new PeriodicTimer(TimeSpan.FromSeconds(3));
        _ = PollAsync(cts.Token);
    }

    private Task RefreshAsync()
    {
        connected = StatusService.GetConnectedStudents();
        return Task.CompletedTask;
    }

    private async Task PollAsync(CancellationToken token)
    {
        try
        {
            while (await timer!.WaitForNextTickAsync(token))
            {
                await RefreshAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            cts?.Cancel();
            timer?.Dispose();
        }
        catch { }
    }
}