Welcome to your new app.
@* @page "/"
@using Microsoft.AspNetCore.SignalR.Client
@using StudentWifiMonitoring.Web.Data
@using StudentWifiMonitoring.Web.Domain
@inject AppDbContext Db
@inject NavigationManager Nav

<h3>Docent Dashboard</h3>

<select @bind-Value="selectedTestId" @bind-Value:event="onchange">
    <option value="">-- Kies toets --</option>
    @foreach (var t in tests)
    {
        <option value="@t.Id">@t.Name (@t.StartTime.ToLocalTime() - @t.EndTime.ToLocalTime())</option>
    }
</select>

@if (students == null)
{
    <p>Laden...</p>
}
else
{
    <table>
        <thead><tr><th>Naam</th><th>Toets</th><th>MAC</th><th>Status</th></tr></thead>
        <tbody>
        @foreach (var s in students)
        {
            var isOnline = onlineMacs.Contains(s.MacAddress);
            <tr>
                <td>@s.Name</td>
                <td>@s.TestName</td>
                <td>@s.MacAddress</td>
                <td style="font-weight:bold; color:@(isOnline ? "green" : "red")">@(isOnline ? "connected" : "disconnected")</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<Student>? students;
    private HashSet<string> onlineMacs = new();
    private List<TestSession> tests = new();
    private int? selectedTestId;
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        tests = Db.TestSessions.OrderByDescending(t => t.StartTime).ToList();
        await LoadStudents();

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/status"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<object>("status", msg =>
        {
            var mac = msg.GetType().GetProperty("mac")?.GetValue(msg)?.ToString();
            var status = msg.GetType().GetProperty("status")?.GetValue(msg)?.ToString();
            if (mac != null && status != null)
            {
                if (status == "connected") onlineMacs.Add(mac); else onlineMacs.Remove(mac);
                InvokeAsync(StateHasChanged);
            }
        });

        await hubConnection.StartAsync();
    }

    private Task LoadStudents()
    {
        if (selectedTestId.HasValue)
        {
            var test = Db.TestSessions.Find(selectedTestId.Value);
            if (test != null)
            {
                students = Db.Students.Where(s => s.TestName == test.Name).ToList();
                onlineMacs = Db.Connections
                    .Where(c => c.DisconnectedAt == null && c.Student!.TestName == test.Name)
                    .Select(c => c.Student!.MacAddress)
                    .ToHashSet();
            }
        }
        else
        {
            students = Db.Students.ToList();
            onlineMacs = Db.Connections.Where(c => c.DisconnectedAt == null).Select(c => c.Student!.MacAddress).ToHashSet();
        }
        return Task.CompletedTask;
    }

    private async Task OnTestChanged(ChangeEventArgs e)
    {
        if (int.TryParse(Convert.ToString(e.Value), out var id)) selectedTestId = id; else selectedTestId = null;
        await LoadStudents();
        StateHasChanged();
    }
} *@