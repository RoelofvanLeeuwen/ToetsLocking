@page "/"
@using Microsoft.AspNetCore.SignalR.Client
@using StudentWifiMonitoring.Web.Domain
@using StudentWifiMonitoring.Web.DTOs.Dashboard
@using StudentWifiMonitoring.Web.DTOs.Tests
@using StudentWifiMonitoring.Web.Services.Interfaces
@inject IDashboardService DashboardService
@inject ITeacherAuthService TeacherAuth
@inject PersistentComponentState AppState
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject StudentWifiMonitoring.Web.Services.IMacResolver MacResolver
@inject StudentWifiMonitoring.Web.Services.Interfaces.IMyScreenService MyScreenService
@implements IAsyncDisposable

<PageTitle>Dashboard — Toetslocker</PageTitle>

@if (!isTeacher)
{
    <div class="tl-empty">
        <div class="ic"><TLIcon Name="lock" Size="32" /></div>
        <h3>Geen toegang</h3>
        <p>Deze pagina is alleen beschikbaar voor docenten.</p>
    </div>
}
else
{
    <div class="tl-ph">
        <h1>Dashboard</h1>
        <p>Realtime monitoring van verbonden studenten</p>
    </div>

    <div class="tl-toolbar">
        <div class="tl-sel-wrap">
            <label>Actieve toets</label>
            <select @bind="selectedTestId" @bind:after="OnTestChanged">
                <option value="">— Kies een toets —</option>
                @foreach (TestSessionDto t in tests)
                {
                    <option value="@t.Id">@t.Name (@t.StartTime.ToLocalTime().ToString("HH:mm") – @t.EndTime.ToLocalTime().ToString("HH:mm"))</option>
                }
            </select>
        </div>
        <div class="tl-signal">
            <i></i>
            <span class="lbl">SignalR</span>
            @(_isConnected ? "Verbonden" : "Niet verbonden")
        </div>
    </div>

    <div class="tl-tiles d4">
        <div class="tl-tile">
            <span class="tl-tile-ic n"><TLIcon Name="users" Size="22" /></span>
            <div><div class="v">@(students?.Count ?? 0)</div><div class="k">Totaal</div></div>
        </div>
        <div class="tl-tile">
            <span class="tl-tile-ic g"><TLIcon Name="wifi" Size="22" /></span>
            <div><div class="v">@(students?.Count(s => s.IsOnline && !s.IsTestComplete) ?? 0)</div><div class="k">Verbonden</div></div>
        </div>
        <div class="tl-tile">
            <span class="tl-tile-ic t"><TLIcon Name="flag" Size="22" /></span>
            <div><div class="v">@(students?.Count(s => s.IsTestComplete) ?? 0)</div><div class="k">Klaar</div></div>
        </div>
        <div class="tl-tile">
            <span class="tl-tile-ic r"><TLIcon Name="wifi-off" Size="22" /></span>
            <div><div class="v">@(students?.Count(s => !s.IsOnline && !s.IsTestComplete) ?? 0)</div><div class="k">Verbroken</div></div>
        </div>
    </div>

    <div class="tl-panel">
        <div class="tl-panel-head">
            <span class="tl-panel-title">Studenten</span>
        </div>

        @if (students == null)
        {
            <div class="tl-empty">
                <p>Laden…</p>
            </div>
        }
        else if (students.Count == 0)
        {
            <div class="tl-empty">
                <div class="ic"><TLIcon Name="users" Size="32" /></div>
                @if (!selectedTestId.HasValue)
                {
                    <h3>Selecteer een toets</h3>
                    <p>Kies een toets in het dropdown-menu om de studenten te bekijken.</p>
                }
                else
                {
                    <h3>Geen studenten</h3>
                    <p>Er zijn nog geen studenten geregistreerd voor deze toets.</p>
                }
            </div>
        }
        else
        {
            <div class="tl-tablewrap">
                <table class="tl-dtable">
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Naam</th>
                            <th>Toets</th>
                            <th>MAC-adres</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (StudentStatusDto s in students.OrderByDescending(st => st.IsOnline && !st.IsTestComplete).ThenByDescending(st => st.IsTestComplete).ThenByDescending(st => st.LastConnectedAt))
                        {
                            <tr class="row" @onclick="() => OpenStudentDetail(s)">
                                <td>
                                    <div class="tl-status-cell">
                                        @if (s.IsTestComplete)
                                        {
                                            <span class="tl-spill klaar"><i></i>Klaar</span>
                                        }
                                        else if (s.IsOnline)
                                        {
                                            <span class="tl-spill verbonden"><i></i>Verbonden</span>
                                        }
                                        else
                                        {
                                            <span class="tl-spill niet"><i></i>Niet verbonden</span>
                                        }
                                        @if (s.DisconnectionCount > 0)
                                        {
                                            <span class="tl-dc-badge"><TLIcon Name="alert" Size="12" /> @s.DisconnectionCount×</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="tl-name-cell">
                                        <div class="av" style="background:linear-gradient(135deg,#6D5BFF,#4A2EE0)">@GetStudentInitials(s.Name)</div>
                                        <span class="nm">@s.Name</span>
                                    </div>
                                </td>
                                <td>@s.TestName</td>
                                <td class="tl-mac-cell">@s.MacAddress</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="tl-totals">
                <span>Totaal: <b>@students.Count</b></span>
                <span class="g">Verbonden: <b>@students.Count(s => s.IsOnline && !s.IsTestComplete)</b></span>
                <span>Klaar: <b>@students.Count(s => s.IsTestComplete)</b></span>
                <span class="gr">Verbroken: <b>@students.Count(s => !s.IsOnline && !s.IsTestComplete)</b></span>
            </div>
        }
    </div>
}

@if (selectedStudent != null)
{
    <div class="tl-modal-scrim" @onclick="CloseStudentDetail">
        <div class="tl-modal" @onclick:stopPropagation="true">
            <div class="tl-modal-head">
                <div class="av">@GetStudentInitials(selectedStudent.Name)</div>
                <div>
                    <div class="t">@selectedStudent.Name</div>
                    <div class="s">Activiteitenlog</div>
                </div>
                <button class="x" @onclick="CloseStudentDetail"><TLIcon Name="close" Size="18" /></button>
            </div>
            <div class="tl-modal-body">
                @if (studentActivity == null || !studentActivity.Any())
                {
                    <p style="color:var(--tl-ink-3);padding:16px 0">Geen activiteiten gevonden voor deze student.</p>
                }
                else
                {
                    <ul class="tl-tl">
                        @foreach (StudentActivityDto a in studentActivity)
                        {
                            <li>
                                @if (a.EventType == EventType.Disconnected)
                                {
                                    <span class="dot verbroken"></span>
                                    <span class="time">@a.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                    <span class="ev verbroken">Verbinding verbroken</span>
                                }
                                else if (a.EventType == EventType.TestCompleted)
                                {
                                    <span class="dot klaar"></span>
                                    <span class="time">@a.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                    <span class="ev">Ik ben klaar</span>
                                }
                                else
                                {
                                    <span class="dot verbonden"></span>
                                    <span class="time">@a.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                    <span class="ev">Verbonden — @a.StudentName</span>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
            <div class="tl-modal-foot">
                <span class="ct">
                    <TLIcon Name="alert" Size="14" />
                    @(studentActivity?.Count(a => a.EventType == EventType.Disconnected) ?? 0) verbroken verbinding(en)
                </span>
                <button class="tl-btn tl-btn-ghost" style="margin-left:auto" @onclick="CloseStudentDetail">Sluiten</button>
            </div>
        </div>
    </div>
}

@code {
    private bool isTeacher;
    private PersistingComponentStateSubscription _persistSubscription;
    private List<StudentStatusDto>? students;
    private List<TestSessionDto> tests = new();
    private int? selectedTestId;
    private HubConnection? hubConnection;
    private string? _connectionStatus;
    private bool _isConnected;
    private StudentStatusDto? selectedStudent;
    private List<StudentActivityDto>? studentActivity;

    protected override async Task OnInitializedAsync()
    {
        _persistSubscription = AppState.RegisterOnPersisting(PersistAuthState);

        if (AppState.TryTakeFromJson<bool>("isTeacher", out bool restored))
        {
            isTeacher = restored;
        }
        else
        {
            isTeacher = TeacherAuth.IsTeacher();
        }

        if (!isTeacher)
        {
            var ip = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString();
            if (!string.IsNullOrEmpty(ip))
            {
                var mac = MacResolver.GetMacForIp(ip);
                if (!string.IsNullOrEmpty(mac))
                {
                    var status = await MyScreenService.GetStudentConnectionStatusAsync(mac);
                    Nav.NavigateTo(status.IsConnected && !status.IsTestComplete ? "/myscreen" : "/register");
                    return;
                }
            }
            Nav.NavigateTo("/register");
            return;
        }

        // Laad initiële data; selecteer automatisch de actieve toets
        tests = DashboardService.GetTestSessions();
        selectedTestId = tests.FirstOrDefault(t => t.IsActive)?.Id;
        LoadStudents();

        // Setup SignalR verbinding
        await SetupSignalRConnectionAsync();

        // Herlaad na verbinden om events te missen tijdens navigatie te compenseren
        LoadStudents();
    }

    private Task PersistAuthState()
    {
        AppState.PersistAsJson("isTeacher", isTeacher);
        return Task.CompletedTask;
    }

    /// <summary>
    /// Bouwt de SignalR HubConnection op en luistert naar status events.
    /// </summary>
    private async Task SetupSignalRConnectionAsync()
    {
        try
        {
            // Blazor Server: componentcode draait server-side. Nav.ToAbsoluteUri() geeft
            // de externe hostnaam (bijv. toetslocker.lan) die de server niet zelf kan resolven.
            // Gebruik localhost met de poort uit de browser-URL zodat de server zichzelf bereikt.
            var port = new Uri(Nav.BaseUri).Port;
            hubConnection = new HubConnectionBuilder()
                .WithUrl($"http://localhost:{port}/hubs/status")
                .WithAutomaticReconnect()
                .Build();

            // Luister naar status events van MonitoringService
            hubConnection.On<StatusUpdatePayload>("status", async (payload) =>
            {
                await HandleStatusUpdateAsync(payload);
            });

            // Connection status tracking
            hubConnection.Reconnecting += error =>
            {
                _connectionStatus = "Opnieuw verbinden...";
                _isConnected = false;
                InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            };

            hubConnection.Reconnected += connectionId =>
            {
                _connectionStatus = "Opnieuw verbonden";
                _isConnected = true;
                LoadStudents(); // Reload data na reconnect
                InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            };

            hubConnection.Closed += error =>
            {
                _connectionStatus = "Verbinding verbroken";
                _isConnected = false;
                InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            };

            // Start verbinding
            await hubConnection.StartAsync();
            _connectionStatus = "Verbonden met SignalR";
            _isConnected = true;
        }
        catch (Exception ex)
        {
            _connectionStatus = $"Fout bij verbinden: {ex.Message}";
            _isConnected = false;
        }
    }

    /// <summary>
    /// Verwerkt een realtime status update van MonitoringService via SignalR.
    /// </summary>
    private async Task HandleStatusUpdateAsync(StatusUpdatePayload payload)
    {
        try
        {
            if (string.IsNullOrEmpty(payload.Mac) || string.IsNullOrEmpty(payload.Status))
                return;

            if (students != null)
            {
                StudentStatusDto? existingStudent = students.FirstOrDefault(s => s.MacAddress == payload.Mac);

                if (existingStudent != null)
                {
                    if (payload.Status == "testcomplete")
                    {
                        existingStudent.IsOnline = false;
                        existingStudent.IsTestComplete = true;
                    }
                    else
                    {
                        if (payload.Status == "connected")
                            existingStudent.IsTestComplete = false;

                        bool wasOnline = existingStudent.IsOnline;
                        existingStudent.IsOnline = payload.Status == "connected";

                        if (wasOnline && !existingStudent.IsOnline)
                            existingStudent.DisconnectionCount++;

                        if (!wasOnline && existingStudent.IsOnline)
                            existingStudent.LastConnectedAt = DateTime.UtcNow;

                        if (!string.IsNullOrEmpty(payload.Name) && existingStudent.Name != payload.Name)
                            existingStudent.Name = payload.Name;

                        if (!string.IsNullOrEmpty(payload.TestName) && existingStudent.TestName != payload.TestName)
                            existingStudent.TestName = payload.TestName;
                    }
                }
                else if (!string.IsNullOrEmpty(payload.Name) && selectedTestId.HasValue)
                {
                    students.Add(new StudentStatusDto
                    {
                        MacAddress = payload.Mac,
                        Name = payload.Name,
                        TestName = payload.TestName ?? "Onbekend",
                        IsOnline = payload.Status == "connected"
                    });
                }
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fout bij verwerken status update: {ex.Message}");
        }
    }

    /// <summary>
    /// Laadt studenten en hun online status uit de database.
    /// Toont geen studenten als geen toets geselecteerd is.
    /// </summary>
    private void LoadStudents()
    {
        if (!selectedTestId.HasValue)
        {
            students = new List<StudentStatusDto>();
            return;
        }
        students = DashboardService.GetStudentsWithStatus(selectedTestId);
    }

    /// <summary>
    /// Handler voor toets selectie wijziging.
    /// </summary>
    private void OnTestChanged()
    {
        LoadStudents();
    }

    private void OpenStudentDetail(StudentStatusDto student)
    {
        selectedStudent = student;
        studentActivity = DashboardService.GetStudentActivity(student.MacAddress, selectedTestId);
    }

    private void CloseStudentDetail()
    {
        selectedStudent = null;
        studentActivity = null;
    }

    private static string GetStudentInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var words = name.Split(' ', System.StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(words.Take(2).Select(w => char.ToUpper(w[0])));
    }

    /// <summary>
    /// Cleanup SignalR verbinding bij dispose.
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        _persistSubscription.Dispose();
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    /// <summary>
    /// Payload structuur voor status updates van MonitoringService.
    /// </summary>
    private class StatusUpdatePayload
    {
        public string Mac { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string? Name { get; set; }
        public string? TestName { get; set; }
    }
}
