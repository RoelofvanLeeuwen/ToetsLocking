@page "/export-by-test"
@using StudentWifiMonitoring.Web.DTOs.Export
@using StudentWifiMonitoring.Web.DTOs.Tests
@using StudentWifiMonitoring.Web.Services.Interfaces
@inject IExportService ExportService
@inject IJSRuntime JS

<TeacherGuard>
<h3>Export per Toets</h3>

<select @bind-Value="selectedTestId" @bind-Value:event="onchange">
    <option value="">-- Kies toets --</option>
    @foreach (TestSessionDto t in tests)
    {
        <option value="@t.Id">@t.Name (@t.StartTime.ToLocalTime() - @t.EndTime.ToLocalTime())</option>
    }
</select>
<button @onclick="Export">Download CSV</button>
<p>@message</p>
</TeacherGuard>

@code {
    private List<TestSessionDto> tests = new();
    private int? selectedTestId;
    private string? message;

    protected override void OnInitialized()
    {
        tests = ExportService.GetTestSessions();
    }

    private async Task Export()
    {
        if (selectedTestId == null) { message = "Geen toets geselecteerd."; return; }

        ExportResultDto result = await ExportService.ExportByTestAsync(selectedTestId.Value);

        if (result.Success && result.CsvContent != null && result.FileName != null)
        {
            await JS.InvokeVoidAsync("downloadCsvFile", result.FileName, result.CsvContent);
            message = $"Download gestart: {result.FileName}";
        }
        else
        {
            message = result.ErrorMessage;
        }
    }
}