@page "/teacher"
@using StudentWifiMonitoring.Web.Services.Interfaces
@rendermode InteractiveServer
@inject ITeacherAuthService TeacherAuth
@inject NavigationManager Nav

<PageTitle>Docent inloggen — Toetslocker</PageTitle>

<div class="tl-auth-bg tl-root">
    <div class="tl-auth-card">
        <div class="tl-auth-head">
            <div class="ic"><TLLogoMark Size="30" /></div>
            <div class="t">Docent inloggen</div>
        </div>
        <div class="tl-auth-body">
            @if (_isLoggedIn)
            {
                <div class="tl-auth-ok">
                    <TLIcon Name="shield" Size="18" />
                    Ingelogd als docent
                </div>
                <a href="/" class="tl-btn tl-btn-brand">
                    <TLIcon Name="grid" Size="18" /> Naar dashboard
                </a>

                @* Logout verloopt via een echte HTTP POST zodat het cookie verwijderd kan worden *@
                <form method="post" action="/api/teacher/logout">
                    <button type="submit" class="tl-btn tl-btn-ghost">
                        <TLIcon Name="logout" Size="18" /> Uitloggen
                    </button>
                </form>
            }
            else
            {
                <p class="tl-auth-hint">Voer de docentpincode in om beheerfunctionaliteit te openen.</p>

                @if (_loginFailed)
                {
                    <div class="tl-auth-err">
                        <TLIcon Name="alert" Size="18" /> Pincode onjuist. Probeer opnieuw.
                    </div>
                }

                @* Login verloopt via een echte HTTP POST zodat het cookie vóór de response gezet kan worden.
                   Blazor session writes zijn niet mogelijk nadat de response gestart is. *@
                <form method="post" action="/api/teacher/login">
                    <div class="tl-fld" style="margin-bottom:18px">
                        <label>Pincode</label>
                        <input type="password"
                               name="pin"
                               class="tl-in"
                               placeholder="Voer pincode in"
                               autofocus />
                    </div>
                    <button type="submit" class="tl-btn tl-btn-brand">
                        <TLIcon Name="lock" Size="18" /> Inloggen
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@code {
    private bool _loginFailed;
    private bool _isLoggedIn;

    protected override void OnInitialized()
    {
        _isLoggedIn = TeacherAuth.IsTeacher();

        // Toon foutmelding als de login mislukt is (teruggestuurd door het login-endpoint)
        var uri = new Uri(Nav.Uri);
        _loginFailed = System.Web.HttpUtility.ParseQueryString(uri.Query)["fout"] == "1";
    }
}
