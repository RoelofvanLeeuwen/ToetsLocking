{
  // Alle waarden hieronder kunnen in Docker overschreven worden via environment variables.
  // ASP.NET Core gebruikt dubbele underscore als separator voor geneste keys, bijvoorbeeld:
  //   ConnectionStrings__Default=Data Source=/data/app.db
  //   Monitoring__Interface=eth1
  //   Monitoring__PollSeconds=2
  //   Teacher__Password=geheimwachtwoord
  //   ForceHttps=false
  "ConnectionStrings": {
    // Relatief pad voor lokale ontwikkeling.
    // In Docker: mount een volume en overschrijf naar een absoluut pad, bijv. /data/app.db
    "Default": "Data Source=app.db"
  },
  "Monitoring": {
    // Netwerkinterface voor WiFi/ethernet monitoring.
    // Lokale ontwikkeling: wlan0 (of irrelevant, Windows gebruikt MockStationProvider).
    // Productie op Raspberry Pi: eth1 (overschrijf via Docker environment variable Monitoring__Interface=eth1)
    "Interface": "wlan0",
    "PollSeconds": 2
  },
  "Network": {
    // Ethernet-interface waarvan het IP-adres getoond wordt op de Netwerk-pagina.
    // Op de Raspberry Pi meestal eth0 (de bekabelde verbinding).
    "EthernetInterface": "eth0"
  },
  "Teacher": {
    // Standaardwaarde alleen voor lokale ontwikkeling.
    // In productie ALTIJD overschrijven via Docker environment variable: Teacher__Password=<pincode>
    "Password": "1234"
  },
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "http://*:80"
      }
    }
  },
  // Zet op true als de applicatie achter HTTPS draait en redirect gewenst is.
  // Op de Raspberry Pi zonder TLS-certificaat op false laten.
  "ForceHttps": false,
  "AllowedHosts": "*"
}
